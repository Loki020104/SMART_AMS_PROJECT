# SmartAMS Environment Configuration Template
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to git - it contains secrets!

# ─── Supabase Configuration ────────────────────────────
# Get these from: https://app.supabase.com → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key-here

# ─── PostgreSQL Database Configuration ────────────────────────────
# Local development database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=smartams
DB_USER=postgres
DB_PASSWORD=postgres

# ─── Flask Configuration ────────────────────────────
FLASK_DEBUG=True
FLASK_ENV=development
SECRET_KEY=change-this-in-production

# ─── QR Security - Generated Keys ────────────────────────────
QR_ENCRYPTION_KEY=your-encryption-key-here
QR_HMAC_SECRET=your-hmac-secret-here

# ─── Face Recognition Configuration ────────────────────────────
# Options: 'mtcnn' (accurate) or 'hog' (fast)
FACE_DETECTION_MODEL=mtcnn

# Confidence threshold (0-1)
FACE_THRESHOLD=0.6

# Minimum quality score (0-100)
FACE_QUALITY_MIN=50
FACE_QUALITY_THRESHOLD=0.5
MTCNN_CONFIDENCE=0.95

# Enable eye blinking detection
LIVENESS_DETECTION=True

# ─── Face Augmentation Configuration ────────────────────────────
# Generate augmented variants for training robustness
ENABLE_AUGMENTATION=True
AUGMENTATION_COUNT=5
PRESERVE_FACE_QUALITY=True

# ─── Firebase Configuration ────────────────────────────
# Get from Firebase Console → Project Settings
FIREBASE_PROJECT_ID=smart-ams-project-faa5f
FIREBASE_API_KEY=your-firebase-api-key-here

# Optional: Service account path for Firebase Admin SDK
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/serviceAccountKey.json

# ─── JWT Configuration ────────────────────────────
JWT_SECRET_KEY=your-jwt-secret-key-here
JWT_EXPIRY_HOURS=24

# ─── University Configuration ────────────────────────────
UNI_ABBR=PUC
