# 🔐 SmartAMS - SECURE ENVIRONMENT VARIABLES
# Copy this file to .env and fill in your actual values
# ⚠️  DO NOT commit .env to git - it contains secrets!
# ⚠️  Enable .env entry in .gitignore

# ═══════════════════════════════════════════════════════════════════════════
# 🚨 PRODUCTION SECURITY CHECKLIST
# ═══════════════════════════════════════════════════════════════════════════
# ✓ All secrets generated with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# ✓ Never use development secrets in production
# ✓ Rotate secrets every 90 days
# ✓ HTTPS (TLS 1.2+) enabled
# ✓ Database access restricted to backend only
# ✓ Rate limiting enabled on all endpoints
# ✓ Audit logging enabled
# ✓ Monitor logs for suspicious activity

# ═══════════════════════════════════════════════════════════════════════════
# FLASK CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════

# Environment: development|staging|production
FLASK_ENV=production

# Debug mode (MUST be False in production)
FLASK_DEBUG=False

# Port
FLASK_PORT=6001

# Session secret key (generate new)
SECRET_KEY=change-this-in-production

# ═══════════════════════════════════════════════════════════════════════════
# SUPABASE CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════
# Get these from: https://app.supabase.com → Project Settings → API

# Supabase project URL
SUPABASE_URL=https://your-project.supabase.co

# Supabase anon/public key (for backend use only)
# 🔐 CRITICAL: Keep secret, never expose in frontend code
SUPABASE_KEY=your-supabase-anon-key-here

# Supabase service role key (admin operations only)
# 🔐 CRITICAL: Only use in backend, never expose to frontend
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ═══════════════════════════════════════════════════════════════════════════
# FIREBASE CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════

# Firebase project ID
FIREBASE_PROJECT_ID=smart-ams-project-faa5f

# Firebase database URL
FIREBASE_DB_URL=https://smart-ams-project-faa5f-default-rtdb.firebaseio.com

# ═══════════════════════════════════════════════════════════════════════════
# AUTHENTICATION & SECURITY TOKENS
# ═══════════════════════════════════════════════════════════════════════════

# JWT secret key for token signing
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=your-jwt-secret-here

# ─── QR Security - Generated Keys ────────────────────────────
QR_ENCRYPTION_KEY=your-encryption-key-here
QR_HMAC_SECRET=your-hmac-secret-here

# ─── Face Recognition Configuration ────────────────────────────
# Options: 'mtcnn' (accurate) or 'hog' (fast)
FACE_DETECTION_MODEL=mtcnn

# Confidence threshold (0-1)
FACE_THRESHOLD=0.6

# Minimum quality score (0-100)
FACE_QUALITY_MIN=50
FACE_QUALITY_THRESHOLD=0.5
MTCNN_CONFIDENCE=0.95

# Enable eye blinking detection
LIVENESS_DETECTION=True

# ─── Face Augmentation Configuration ────────────────────────────
# Generate augmented variants for training robustness
ENABLE_AUGMENTATION=True
AUGMENTATION_COUNT=5
PRESERVE_FACE_QUALITY=True

# ─── Firebase Configuration ────────────────────────────
# Get from Firebase Console → Project Settings
FIREBASE_PROJECT_ID=smart-ams-project-faa5f
FIREBASE_API_KEY=your-firebase-api-key-here

# Optional: Service account path for Firebase Admin SDK
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/serviceAccountKey.json

# ─── JWT Configuration ────────────────────────────
JWT_SECRET_KEY=your-jwt-secret-key-here
JWT_EXPIRY_HOURS=24

# ─── University Configuration ────────────────────────────
UNI_ABBR=PUC
