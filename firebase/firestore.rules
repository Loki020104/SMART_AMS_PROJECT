rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // *** SMART AMS FIRESTORE SECURITY RULES ***
    // Production-ready with role-based access control
    
    // Default: Deny all access (most restrictive)
    match /{document=**} {
      allow read, write: if false;
    }
    
    // Users collection - must be authenticated
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth.uid == userId;
      allow delete: if false;  // No user deletion via Firestore
      
      // User attendance subcollection
      match /attendance/{attendanceId} {
        allow read, write: if request.auth != null;
      }
      
      // User marks subcollection
      match /marks/{courseId} {
        allow read, write: if request.auth != null;
      }
    }
    
    // Attendance records - read for authenticated, write controlled by backend
    match /attendance/{attendanceId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
      allow delete: if false;
    }
    
    // QR Sessions - for real-time attendance check-in
    match /qr_sessions/{sessionId} {
      allow read: if true;  // QR sessions are public (sessionId is auth)
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.time > resource.data.expires_at;  // Auto-expire
    }
    
    // Courses collection
    match /courses/{courseId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;  // Controlled by backend
      allow delete: if false;
      
      // Course announcements
      match /announcements/{annoId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null;
      }
    }
    
    // Timetable data
    match /timetable/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
      allow delete: if false;
    }
    
    // Global announcements
    match /announcements/{annoId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;  // Backend will verify admin
      allow delete: if false;
    }
    
    // Reports collection
    match /reports/{reportId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if false;
    }
    
    // Departments
    match /departments/{deptId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;  // Backend will verify admin
      allow delete: if false;
    }
    
    // Programs
    match /programs/{progId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;  // Backend will verify admin
      allow delete: if false;
    }
    
    // Face encodings (for face recognition)
    match /face_encodings/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == userId || request.auth != null;
      allow delete: if request.auth.uid == userId;
    }
  }
}
