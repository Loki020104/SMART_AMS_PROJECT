rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Allow unauthenticated read/write for development
    // Change this for production with proper authentication
    
    // Session storage (for app session persistence)
    match /sessions/{username} {
      allow read, write: if true;
    }
    
    // Users collection
    match /users/{userId} {
      allow read, write: if request.auth != null || true;
      
      // Subcollection for attendance
      match /attendance/{docId} {
        allow read, write: if request.auth != null || true;
      }
    }
    
    // Students collection
    match /students/{studentId} {
      allow read, write: if request.auth != null || true;
      
      // Subcollection for face encodings
      match /face_data/{docId} {
        allow read, write: if request.auth != null || true;
      }
    }
    
    // Attendance records
    match /attendance/{docId} {
      allow read, write: if request.auth != null || true;
    }
    
    // QR sessions
    match /qr_sessions/{sessionId} {
      allow read, write: if request.auth != null || true;
      
      allow delete: if request.time > resource.data.expires_at;
    }
    
    // Reports
    match /reports/{reportId} {
      allow read, write: if request.auth != null || true;
    }
    
    // Course data
    match /courses/{courseId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Faculty data
    match /faculty/{facultyId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Frontend sessions (username/password login — no Firebase Auth token)
    match /sessions/{username} {
      allow read, write, delete: if true;
    }
  }
}
